{
  "name": "ai-provider-manager",
  "version": "0.4.0",
  "displayName": "AI Provider Manager",
  "description": "Verwalte verschiedene KI-Provider und chatte direkt in VS Code",
  "publisher": "developer",
  "repository": "https://github.com/brokmann-kai/VSCode-KI-Erweiterung",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiProviderManager.configure",
    "onCommand:aiProviderManager.addProvider",
    "onCommand:aiProviderManager.setActiveProvider",
    "onView:ai-provider-manager-view"
  ],
  "main": "./out/main.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-provider-manager-sidebar",
          "title": "AI Provider",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ai-provider-manager-sidebar": [
        {
          "id": "ai-provider-manager-view",
          "name": "Provider",
          "when": "view == ai-provider-manager-view"
        }
      ]
    },
    "commands": [
      {
        "command": "aiProviderManager.configure",
        "title": "⚙️ Provider Einstellungen",
        "category": "AI Provider"
      },
      {
        "command": "aiProviderManager.addProvider",
        "title": "➕ Neuer Provider",
        "category": "AI Provider"
      },
      {
        "command": "aiProviderManager.setActiveProvider",
        "title": "✅ Als Aktiv setzen",
        "category": "AI Provider"
      },
      {
        "command": "aiProviderManager.showQuickPick",
        "title": "🔄 Provider wechseln",
        "category": "AI Provider"
      },
      {
        "command": "aiProviderManager.chatWithProvider",
        "title": "💬 Mit Provider chatten",
        "category": "AI Provider"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aiProviderManager.addProvider",
          "when": "view == ai-provider-manager-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "aiProviderManager.setActiveProvider",
          "when": "view == ai-provider-manager-view"
        },
        {
          "command": "aiProviderManager.configure",
          "when": "view == ai-provider-manager-view"
        }
      ]
    },
    "configuration": {
      "title": "AI Provider Manager",
      "properties": {
        "aiProviderManager.configPath": {
          "type": "string",
          "default": "~/.ai-provider-manager/config.json",
          "description": "Pfad zur Konfigurationsdatei"
        },
        "aiProviderManager.streaming": {
          "type": "boolean",
          "default": true,
          "description": "Streaming Responses aktivieren"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  }
}
