{
  "name": "ai-provider-manager",
  "version": "0.5.0",
  "displayName": "AI Provider Manager",
  "description": "Verwalte verschiedene KI-Provider und chatte direkt in VS Code",
  "publisher": "developer",
  "repository": "https://github.com/brokmann-kai/VSCode-KI-Erweiterung",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiProviderManager.configure",
    "onCommand:aiProviderManager.addProvider",
    "onCommand:aiProviderManager.setActiveProvider",
    "onCommand:aiProviderManager.showQuickPick",
    "onView:ai-provider-manager-view"
  ],
  "main": "./out/main.js",
  "contributes": {
    "commands": [
      {
        "command": "aiProviderManager.configure",
        "title": "⚙️ KI Provider - Einstellungen",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.addProvider",
        "title": "➕ KI Provider - Neuer Provider",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.setActiveProvider",
        "title": "✅ KI Provider - Als aktiv setzen",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.showQuickPick",
        "title": "🔄 KI Provider - Wechseln",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.chatWithProvider",
        "title": "💬 KI Provider - Chatten",
        "category": "KI Provider"
      }
    ],
    "configuration": {
      "title": "AI Provider Manager",
      "properties": {
        "aiProviderManager.configPath": {
          "type": "string",
          "default": "~/.ai-provider-manager/config.json",
          "description": "Pfad zur Konfigurationsdatei"
        },
        "aiProviderManager.streaming": {
          "type": "boolean",
          "default": true,
          "description": "Streaming Responses aktivieren"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  }
}
