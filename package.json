{
  "name": "ai-provider-manager",
  "version": "0.7.0",
  "displayName": "AI Provider Manager",
  "description": "Verwalte verschiedene KI-Provider und chatte direkt in VS Code",
  "publisher": "developer",
  "repository": "https://github.com/brokmann-kai/VSCode-KI-Erweiterung",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/main.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "aiProviderManager.ai",
        "name": "ai",
        "description": "Chatte mit dem aktiven KI-Provider"
      }
    ],
    "commands": [
      {
        "command": "aiProviderManager.configure",
        "title": "➕ Neuer KI Provider",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.editProvider",
        "title": "🔑 API Key ändern",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.showQuickPick",
        "title": "🔄 KI Provider wechseln",
        "category": "KI Provider"
      },
      {
        "command": "aiProviderManager.chatWithActive",
        "title": "💬 Mit KI chatten",
        "category": "KI Provider"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  }
}
